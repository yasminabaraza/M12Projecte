{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "rootDir": "./src", // aquí dices que tus archivos TS están en src
    "outDir": "./dist", // aquí se generará JS compilado
    "esModuleInterop": true,
    "strict": true
  },
  "include": ["src"] // le dices a TS que solo compile src
}
