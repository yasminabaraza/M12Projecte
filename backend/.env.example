# Còpia aquest fitxer a backend/.env (no es puja al repo)
# Format: postgresql://el_meu_usuari_local:el_meu_password_local@localhost:5432/abyssal_db?schema=public
DATABASE_URL=

# JWT
TOKEN_SECRET=your-secret-key-here
TOKEN_EXPIRES_IN=7d

# CORS (URL del frontend en producció)
FRONTEND_URL=http://localhost:3000
