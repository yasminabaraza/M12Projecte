generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

/**
 * Els camps `role` i `status` es modelen mitjançant enums per garantir
 * la integritat dels valors possibles i evitar estats invàlids.
 * Es tracta de conceptes tancats propis del domini del joc, que no
 * canviaran al llarg del temps, assegurant així que només s’introdueixin
 * dades que segueixin l’estàndard establert.
 */

enum Role {
  user
  admin
}

enum GameStatus {
  active
  completed
  ended
}

enum GameEndReason {
  success
  timeExpired
  attemptsExceeded
  abandoned
}

model User {
  id           Int    @id @default(autoincrement())
  email        String @unique
  username     String @unique
  passwordHash String
  role         Role   @default(user)

  // Un usuari pot tenir múltiples partides al llarg del temps. (User 1 -> N Game)
  // La invariant "màxim una partida active per usuari" viu al startGame.usecase,
  // no a BD: mantenim la migració simple i la regla al domini.
  games Game[]
}

model Game {
  id     Int  @id @default(autoincrement())
  userId Int
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)

  status        GameStatus     @default(active)
  endReason     GameEndReason?
  currentRoomId Int?
  currentRoom   Room?          @relation(fields: [currentRoomId], references: [id])

  // Opció per desactivar l'assistent a la partida
  aiEnabled Boolean @default(true)

  // ESTAT DEL JOC (temps, score, pistes, etc.)
  state     Json

  // Puntuació duplicada del state per fer ranking eficient
  score Int @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, status]) // ús funcional (joc actiu per usuari)
  @@index([status, endReason]) // ús analític (estadístiques)
  @@index([status, endReason, score])//index per score
}

model Room {
  id          Int     @id @default(autoincrement())
  code        String  @unique
  name        String
  description String
  image       String? // imatge de la sala (frontend)
  order       Int     @unique // progressió del joc (1,2,3...)
  isInitial   Boolean @default(false)

  // Frases idle que mostra l'assistent ABYSS AI quan el jugador no interacciona
  idlePhrases String[] @default([])

  puzzle  Puzzle?
  objects InteractiveObject[]
  games   Game[]
}

model Puzzle {
  id     Int  @id @default(autoincrement())
  roomId Int  @unique
  room   Room @relation(fields: [roomId], references: [id], onDelete: Cascade)

  title     String
  statement String
  solution  String
  reward    String? // recompenses del puzzle
  hints     Hint[]
}

model Hint {
  id       Int    @id @default(autoincrement())
  puzzleId Int
  puzzle   Puzzle @relation(fields: [puzzleId], references: [id], onDelete: Cascade)

  text  String
  order Int

  @@unique([puzzleId, order])
}

model InteractiveObject {
  id     Int  @id @default(autoincrement())
  roomId Int
  room   Room @relation(fields: [roomId], references: [id], onDelete: Cascade)

  name        String
  description String
  type        String

  isInteractive Boolean @default(true)
  isVisible     Boolean @default(true)

  action String?

  @@index([roomId])
}

model SeedMeta {
  id             Int      @id @default(1)
  structuralHash String
  contentHash    String
  updatedAt      DateTime @updatedAt
}
